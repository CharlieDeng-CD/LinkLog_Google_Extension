{
  "name": "linklog",
  "displayName": "LinkLog",
  "version": "0.1.2",
  "description": "AI Knowledge Graph Browser — select any concept and explore its prerequisites through an interactive knowledge graph.",
  "scripts": {
    "dev": "plasmo dev",
    "generate:icons": "node scripts/generate-icons.js",
    "typecheck": "tsc --noEmit",
    "build": "plasmo build",
    "verify:bundle": "node scripts/verify-extension-bundle.js",
    "smoke:content": "node scripts/smoke-content-overlay.js",
    "smoke:extension": "node scripts/smoke-extension-load.js",
    "package": "plasmo package"
  },
  "engines": {
    "node": ">=22 <23",
    "npm": ">=10 <11"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "@plasmohq/messaging": "0.6.2",
    "@plasmohq/storage": "1.12.0",
    "cytoscape": "^3.30.0",
    "cytoscape-fcose": "^2.2.0",
    "plasmo": "0.90.5",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "alias": {
    "react": "./node_modules/react/index.js",
    "react/jsx-runtime": "./node_modules/react/jsx-runtime.js",
    "react-dom": "./node_modules/react-dom/index.js",
    "react-dom/client": "./node_modules/react-dom/client.js",
    "scheduler": "./node_modules/scheduler/index.js",
    "@mozilla/readability": "./node_modules/@mozilla/readability/index.js"
  },
  "devDependencies": {
    "@plasmohq/prettier-plugin-sort-imports": "4.0.1",
    "@playwright/test": "^1.61.0",
    "@types/chrome": "0.0.287",
    "@types/cytoscape": "^3.21.0",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "playwright": "^1.61.0",
    "prettier": "3.3.3",
    "typescript": "5.6.3"
  },
  "manifest": {
    "host_permissions": [
      "https://*/*",
      "http://*/*"
    ],
    "permissions": [
      "activeTab",
      "storage",
      "scripting",
      "tabs",
      "contextMenus"
    ]
  }
}
